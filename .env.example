# IoT File Server - Configuration
# Copy to .env and adjust: cp .env.example .env

# API key for authentication (X-API-Key header)
API_KEY=changeme

# Server
HOST=0.0.0.0
PORT=8000

# Directories (relative or absolute)
# UPLOAD_DIR=./data/incoming
# DOWNLOAD_DIR=./data/outgoing

# SSL (optional, for HTTPS)
# SSL_CERTFILE=./cert.pem
# SSL_KEYFILE=./key.pem

# Limits
# MAX_FILE_SIZE=52428800  # 50 MB

# Logging
# LOG_FILE=./server.log
