# IoT File Server - Configuration
# Copy to .env and adjust: cp .env.example .env

# API key for authentication (X-API-Key header)
API_KEY=changeme

# Server
HOST=0.0.0.0
PORT=8000

# Directories (relative or absolute)
# UPLOAD_DIR=./data/incoming
# DOWNLOAD_DIR=./data/outgoing

# SSL (optional, for HTTPS)
# SSL_CERTFILE=./cert.pem
# SSL_KEYFILE=./key.pem

# Limits
# MAX_FILE_SIZE=52428800  # 50 MB

# Per-chunk read timeout while receiving an upload (seconds).
# Frees the connection if a device freezes mid-transfer (responds HTTP 408).
# UPLOAD_CHUNK_TIMEOUT=30

# Concurrency (recommended: 2 for Raspberry Pi, 4 for more powerful servers)
# WORKERS=1

# Logging
# server.log        -> operational events + 4xx/5xx on real endpoints
# server.access.log -> one line per HTTP request
# LOG_FILE=./server.log
# ACCESS_LOG_FILE=./server.access.log
# LOG_MAX_BYTES=10485760   # 10 MB per file before rotation
# LOG_BACKUP_COUNT=5       # number of rotated files to keep
