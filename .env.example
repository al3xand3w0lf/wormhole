# Quectel Modem File Server - Konfiguration
# Kopieren nach .env und anpassen: cp .env.example .env

# API Key für Authentifizierung (X-API-Key Header)
API_KEY=changeme

# Server
HOST=0.0.0.0
PORT=8000

# Verzeichnisse (relativ oder absolut)
# UPLOAD_DIR=./data/incoming
# DOWNLOAD_DIR=./data/outgoing

# SSL (optional, für HTTPS)
# SSL_CERTFILE=./cert.pem
# SSL_KEYFILE=./key.pem

# Limits
# MAX_FILE_SIZE=52428800  # 50 MB

# Logging
# LOG_FILE=./server.log
